# === LLM Provider ===
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# Per-agent overrides (optional — defaults to LLM_PROVIDER/LLM_MODEL)
# DIAGNOSTIC_AGENT_PROVIDER=gemini
# DIAGNOSTIC_AGENT_MODEL=gemini-2.5-flash
# RGM_AGENT_PROVIDER=openai
# RGM_AGENT_MODEL=gpt-4o
# BUDGET_AGENT_PROVIDER=gemini
# BUDGET_AGENT_MODEL=gemini-2.5-flash

# === API Keys ===
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# === LangFuse (optional — tracing disabled if empty) ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Application ===
DATA_PATH=data/dataset.csv
INTERVENTIONS_PATH=data/interventions.csv
BUDGET_WEEKLY_ALLOCATION_MXN=10000.0
HEALTH_THRESHOLD=60.0
CORS_ORIGINS=["http://localhost:3000"]

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
