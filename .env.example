# === LLM Provider ===
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# Per-agent overrides (optional — defaults to LLM_PROVIDER/LLM_MODEL)
# DIAGNOSTIC_AGENT_PROVIDER=gemini
# DIAGNOSTIC_AGENT_MODEL=gemini-2.5-flash
# RGM_AGENT_PROVIDER=openai
# RGM_AGENT_MODEL=gpt-4o
# BUDGET_AGENT_PROVIDER=gemini
# BUDGET_AGENT_MODEL=gemini-2.5-flash

# === API Keys ===
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# === LangFuse (optional — tracing disabled if empty) ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Application ===
DATA_PATH=data/dataset.csv
INTERVENTIONS_PATH=data/interventions.csv
BUDGET_WEEKLY_ALLOCATION_MXN=10000.0
HEALTH_THRESHOLD=60.0
# JSON array of allowed origins. In prod, include the Vercel URL.
# Example: ["https://rappi-kam.vercel.app","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# === Frontend ===
# In prod (Vercel), set this to the Railway backend URL:
#   https://<service>.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================
# Backend (Railway):
#   Required: GOOGLE_API_KEY, LLM_PROVIDER, LLM_MODEL, CORS_ORIGINS
#   Railway injects PORT automatically — Procfile/railway.toml use $PORT.
#   Filesystem is ephemeral: backend/data/interventions.csv will NOT
#   persist across redeploys. Acceptable for demo.
#
# Frontend (Vercel):
#   Required: NEXT_PUBLIC_API_URL (set to Railway URL)
#   Must be set at BUILD time — redeploy after changing.
# ============================================================
